{
  "name": "viamorelia-mobile",
  "version": "0.1.0",
  "private": true,
  "description": "Shell nativo Capacitor (Android primero) para ViaMorelia — Fase 1, sin Play Store aún",
  "scripts": {
    "sync": "node ./node_modules/@capacitor/cli/bin/capacitor sync android",
    "open": "node ./node_modules/@capacitor/cli/bin/capacitor open android",
    "copy": "node ./node_modules/@capacitor/cli/bin/capacitor copy android",
    "doctor": "node ./node_modules/@capacitor/cli/bin/capacitor doctor",
    "assets:check": "node ./scripts/check-assets.mjs",
    "icons": "python ./scripts/generate-android-icons.py"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.4",
    "@capacitor/app": "^7.1.0",
    "@capacitor/browser": "^7.0.5",
    "@capacitor/core": "^7.4.4",
    "@capacitor/geolocation": "^7.1.5",
    "@capacitor/share": "^7.0.2",
    "@capacitor/splash-screen": "^7.0.3",
    "@capacitor/status-bar": "^7.0.3"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.4",
    "typescript": "^5.9.2"
  }
}
