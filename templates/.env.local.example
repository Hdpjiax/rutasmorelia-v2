# Supabase Cloud - variables públicas del frontend
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=PEGA_AQUI_TU_ANON_PUBLIC_KEY
NEXT_PUBLIC_USE_REAL_SUPABASE=true

# Sitio (redirect magic link / Google OAuth)
NEXT_PUBLIC_SITE_URL=https://viamorelia.org

# Opcional: basemap PMTiles local/CDN (requiere protocol maplibre-gl-pmtiles)
# NEXT_PUBLIC_PMTILES_URL=pmtiles://https://example.com/morelia.pmtiles

# Admin QA: correos autorizados (server). Separados por coma.
# Sin esta lista, /admin y /api/qa se deniegan en Vercel; en local se permiten.
ADMIN_EMAILS=tu@correo.com
# Opcional, misma lista solo para UI:
# NEXT_PUBLIC_ADMIN_EMAILS=tu@correo.com

# No poner service_role aquí si este archivo puede llegar a cliente o repo.
# SUPABASE_SERVICE_ROLE_KEY solo en scripts privados locales/servidor, nunca NEXT_PUBLIC.
