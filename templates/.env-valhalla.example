# Configuración local estricta para Valhalla/OSRM/OSM/QGIS/GDAL
# Copiar a .env-valhalla en la raíz del proyecto. No subir secretos reales.

# Área de trabajo Windows/WSL
PROJECT_ROOT=C:/dev/rutas-morelia
GIS_WORKDIR=C:/dev/rutas-morelia/data/gis
RAW_INPUT_DIR=C:/dev/rutas-morelia/data/raw-routes
PROCESSED_DIR=C:/dev/rutas-morelia/data/processed
QA_REPORT_DIR=C:/dev/rutas-morelia/data/qa-reports

# Python local
PYTHON_BIN=python
PYTHON_VENV=.venv-gis
PYTHONPATH=./scripts

# CRS / Bounding box Morelia. Ajustar con datos reales antes de correr producción.
TARGET_CRS=EPSG:4326
WORK_CRS=EPSG:6372
MORELIA_BBOX=-101.35,19.55,-101.05,19.85

# OSM local
OSM_PBF=data/osm/morelia.osm.pbf
OSM_SOURCE_PBF=data/osm/mexico-latest.osm.pbf
OSMIUM_BIN=osmium

# Valhalla local
VALHALLA_URL=http://127.0.0.1:8002
VALHALLA_CONF=data/valhalla/valhalla.json
VALHALLA_TILE_DIR=data/valhalla/tiles
VALHALLA_BUILD_DIR=data/valhalla/build
VALHALLA_COSTING=auto
VALHALLA_SHAPE_MATCH=map_snap
VALHALLA_SEARCH_RADIUS_M=40
VALHALLA_GPS_ACCURACY_M=8
VALHALLA_BREAKAGE_DISTANCE_M=80
VALHALLA_STRICT_DISTANCE_MAX_M=18
VALHALLA_REVIEW_DISTANCE_MAX_M=35
VALHALLA_REJECT_DISTANCE_MAX_M=60
VALHALLA_MIN_CONFIDENCE=0.92
VALHALLA_MAX_ROUTE_ELONGATION=1.18

# OSRM local como segunda validación, no como única verdad
OSRM_URL=http://127.0.0.1:5000
OSRM_PROFILE=car
OSRM_MATCH_RADIUS_M=25
OSRM_STRICT_CONFIDENCE=0.90

# QA GIS
MAX_GAP_M=25
MAX_SNAP_DISTANCE_M=18
MAX_OFFROAD_RATIO=0.02
MAX_SIMPLIFY_TOLERANCE_M=2
MIN_ROUTE_LENGTH_M=500
ALLOW_UNMATCHED_PCT=0.00
REQUIRE_TWO_DIRECTIONS=true
ONLY_DIRECTIONS=ida,vuelta

# Mapa
MAP_CENTER_LNG=-101.194
MAP_CENTER_LAT=19.702
MAP_ZOOM=13.3
MAP_STYLE_URL=https://basemaps.cartocdn.com/gl/positron-gl-style/style.json
ROUTE_ARROW_SPACING_Z10=80
ROUTE_ARROW_SPACING_Z14=120
ROUTE_ARROW_SPACING_Z18=160
